  padding-top: 0;         /* belsĆ margĂł finomhangolĂĄs */
  padding-bottom: 0;
}

/* AlapszĂ¶veg szĂ­nĂ©t a <tr style="color: ..."> mĂĄr beĂĄllĂ­tja.
   Itt a linkek/gombok kontrasztjĂĄt hĂșzzuk fel sĂ¶tĂ©t sorban. */
.table tbody tr.row-dark a { color: #fff; }

/* Outline gombok kapjanak fehĂ©r keretet/szĂ¶veget sĂ¶tĂ©t sorban */
.table tbody tr.row-dark .btn-outline-primary,
.table tbody tr.row-dark .btn-outline-secondary,
.table tbody tr.row-dark .btn-outline-light {
  color: #fff;
  border-color: #fff;
}

/* âVastagâ (filled) gombok maradhatnak, de a sĂĄrga/âzĂ¶ld/ânarancs jĂłl lĂĄtszik sĂ¶tĂ©ten is.
   Ha szeretnĂ©d, a warning/success is kaphat kis kontraszt finomĂ­tĂĄst: */
.table tbody tr.row-dark .btn-warning { color: #000; }  /* sĂĄrga gomb fekete felirat */
.table tbody tr.row-dark .btn-success { color: #fff; }  /* zĂ¶ld gomb fehĂ©r felirat */

/* Az infĂł ikon (popover trigger) szĂ­ne is legyen jĂłl olvashatĂł sĂ¶tĂ©t sorban */
.table tbody tr.row-dark .op-note { color: #fff; border-color: rgba(255,255,255,.6); }

/* Hover sĂ¶tĂ©t sorban: maradjon jĂłl olvashatĂł */
.table tbody tr.row-dark:hover { filter: brightness(0.9); }
</style>
