}

/* ha van safe-area (notch), kicsit hagyjunk helyet alul */
@supports (padding: max(0px)) {
  .table-wrap { padding-bottom: max(0px, env(safe-area-inset-bottom)); }
}

/* sticki fejlĂ©chez hĂĄttĂ©r, z-index */
.table-sticky thead th {
  position: sticky;
  top: 0;
  z-index: 2;                 /* hogy a sorok ne fedjĂ©k le */
  background: #f8f9fa;        /* egyezzen a table-light-tal */
}

/* hogy a zebra/row-color is szĂ©pen lĂĄtszĂłdjon scrollnĂĄl is */
.table-sticky tbody tr.row-colored > td {
  background-color: var(--row-color, #fff) !important;
}

/* opcionĂĄlis: a scroll sĂĄv ne tĂ¶rje el a szĂ©leket */
.table-wrap .table {
  margin-bottom: 0;           /* ne adjon extra helyet alul */
}
.popover {
  max-width: none;      /* szĂ©lessĂ©g ne legyen korlĂĄtozva */
  width: auto;
  white-space: pre;     /* sortĂ¶rĂ©sek megtartĂĄsa */
}

.popover .popover-body {
  font-size: 1.25rem;      /* alapĂ©rtelmezĂ©s kb. 0.875rem */
  line-height: 1.4;     /* sorok kĂ¶zĂ¶tti tĂĄvolsĂĄg */
  max-height: 400px;
  overflow-y: auto;
  white-space: pre-wrap;     /* megtartja a sortĂ¶rĂ©st */
  word-wrap: break-word;     /* hosszĂș szavakat is tĂ¶ri */
  max-width: 120ch;          /* kb. 120 karakter szĂ©lessĂ©g */
  font-family: monospace;    /* opcionĂĄlis, ha pontosan 120 char szĂ©lessĂ©get akarsz */
 
}
/* LejĂĄrat kiemelĂ©s */
.due-tag {
  display: inline-block;
  padding: .15rem .45rem;
  border-radius: 999px;
  font-weight: 600;
  font-size: .9rem;
  line-height: 1;
  border: 1px solid rgba(0,0,0,.15);
  /* finom âfĂ©nyudvarâ, hogy szĂ­nes soron is elvĂĄljon */
  box-shadow: 0 0 0 2px rgba(255,255,255,.6);
  text-decoration: none;
  display: inline-block;
}
.due-tag:hover {
  filter: brightness(0.7);
}
.due-tag.is-active {
  outline: 2px solid rgba(0,0,0,.2);
  box-shadow: 0 0 0 2px rgba(255,255,255,.6), inset 0 0 0 999px rgba(0,0,0,.04);
}
.due-overdue  { background: #D32F2F; color: #fff; }  /* mĂĄr lejĂĄrt */
.due-today    { background: #EF6C00; color: #fff; }  /* ma esedĂ©kes */
.due-soon     { background: #1565C0; color: #fff; }  /* kĂ¶zelgĆ (pl. 7 napon belĂŒl) */
.op-note {
  cursor: pointer;
  color: #0d6efd;          /* alap: bootstrap kĂ©k */
  background: transparent;
  border-radius: 10%;
  padding: 2px 6px;
  transition: all .2s;
}

.op-note.active {
  color: #fff;
  background: #0d6efd;     /* aktĂ­v: fehĂ©r ikon kĂ©k kĂ¶rben */
}
.table tbody tr:hover {
  filter: brightness(0.8);  /* 0.9 = 90% fĂ©nyerĆ â sĂ¶tĂ©tebb */
  cursor : pointer;
  transition: filter 0.2s ease, font-weight 0.2s ease;
  /*font-weight : 600;*/
}
.table .btn-thin {
  padding: 0.1rem 0.25rem;   /* belsĆ margĂł (fĂŒggĆleges, vĂ­zszintes) */
  font-size: 0.75rem;        /* betĆ±mĂ©ret kisebb */
  line-height: 1.2;          /* kisebb sormagassĂĄg */
}


/* PP-stĂĄtusz: a kijelĂ¶lt elemek fix "kivĂĄlasztott" szĂ­ne */
select[multiple].status-colored option:checked {
  background: #0d6efd !important; /* Bootstrap primary */
  color: #fff !important;
}

/* fĂłkuszban is maradjon ugyanilyen tĂ¶bb bĂ¶ngĂ©szĆn */
select[multiple].status-colored:focus option:checked {
  background: #0d6efd !important;
  color: #fff !important;
}

/* (opcionĂĄlis) amikor csak hover van kijelĂ¶lĂ©s nĂ©lkĂŒl */
