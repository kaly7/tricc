/* gĂ¶rgethetĆ lista + ragadĂłs fejlĂ©c */
.table-wrap {
  /* az egĂ©sz lista blokk max. magassĂĄga â finomhangolhatĂł */
  max-height: calc(100dvh - 320px);
  overflow: auto;
