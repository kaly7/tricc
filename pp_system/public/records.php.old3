  filter: brightness(0.95);
}

.table .col-actions {
  display: flex;
  gap: .25rem;
  align-items: stretch;   /* !!! minden gomb nyĂșljon ki a cella teljes magassĂĄgĂĄra */
}

.table .col-actions .btn {
  flex: 1 1 auto;         /* opcionĂĄlis: ha tĂ¶bb gomb van, igazodjanak egymĂĄshoz */
