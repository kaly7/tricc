<?php
  $today = new DateTimeImmutable(date('Y-m-d'));
  $due   = new DateTimeImmutable($r['due_at']);
  $diff  = (int)$today->diff($due)->format('%r%a'); // napok: negatív ha lejárt

  if ($diff <= 0) {
    $dueClass = 'due-overdue';
  } elseif ($diff === 1) {
    $dueClass = 'due-today';
  } elseif ($diff <= 7) {
    $dueClass = 'due-soon';
  } else {
    $dueClass = '';
  }
?>
<td>
  <?php if ($dueClass): ?>
    <span class="due-tag <?=$dueClass?>"><?=h($r['due_at'])?></span>
  <?php else: ?>
    <?=h($r['due_at'])?>
  <?php endif; ?>
</td>


