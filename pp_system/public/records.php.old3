    $dueClass = 'due-today';                // ma .. +2 nap
  } elseif ($due <= $plus12) {
    $dueClass = 'due-soon';                 // kĂ¶vetkezĆ 10 nap (ma+3 .. ma+12)
  } else {
    $dueClass = '';
  }
?>
