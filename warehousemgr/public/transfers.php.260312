          <?php endforeach; ?>
          <?php if (!$rows): ?>
            <tr><td colspan="7" class="text-center text-secondary py-4">Nincs megjeleníthető átadás.</td></tr>
          <?php endif; ?>
        </tbody>
      </table>
    </div>
  </div>
</div>

<?php require __DIR__ . '/../app/views/layout/footer.php'; ?>

<?php if ($canManageAny): ?>
<script>
(() => {
  const sourceSelect = document.getElementById('transfer_source_warehouse_id');
  const materialSelect = document.getElementById('transfer_material_id');
  const hintBox = document.getElementById('transfer-stock-hint');
  const stockMap = <?= json_encode($transferStockMap, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;

  function updateTransferStockHint() {
    if (!sourceSelect || !materialSelect || !hintBox) return;

    const warehouseId = sourceSelect.value;
    const materialId = materialSelect.value;
    if (!warehouseId || !materialId) {
      hintBox.classList.add('d-none');
      hintBox.textContent = '';
      return;
    }

    const selectedOption = materialSelect.options[materialSelect.selectedIndex];
    const materialName = selectedOption?.dataset.materialName || selectedOption?.textContent || '';
    const sku = selectedOption?.dataset.materialSku || '';
    const unit = selectedOption?.dataset.materialUnit || '';
    const stockInfo = (stockMap[warehouseId] && stockMap[warehouseId][materialId]) ? stockMap[warehouseId][materialId] : null;
    const qty = stockInfo ? stockInfo.display : '0';
    const parts = [];
    if (sku) parts.push('[' + sku + ']');
    if (materialName) parts.push(materialName);
    hintBox.textContent = 'A forrás raktár aktuális készlete: ' + parts.join(' · ') + ' = ' + qty + (unit ? ' ' + unit : '');
    hintBox.classList.remove('d-none');
  }

  sourceSelect?.addEventListener('change', updateTransferStockHint);
  materialSelect?.addEventListener('change', updateTransferStockHint);
  updateTransferStockHint();
})();
</script>
<?php endif; ?>
