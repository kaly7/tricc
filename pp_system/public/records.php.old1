}
.due-overdue  { background: #D32F2F; color: #fff; }  /* már lejárt */
.due-today    { background: #EF6C00; color: #fff; }  /* ma esedékes */
.due-soon     { background: #1565C0; color: #fff; }  /* közelgő (pl. 7 napon belül) */
.op-note {
